# Initialization container for CVGen
# Performs one-time setup: model pulls, RAG indexing, service verification
FROM python:3.12-slim

WORKDIR /init

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Python packages needed for initialization
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
    requests>=2.31 \
    qdrant-client>=2.7 \
    httpx>=0.27 \
    pydantic>=2.0

# Copy initialization scripts
COPY scripts/health_check.sh scripts/init_rag.py ./

# Make scripts executable
RUN chmod +x health_check.sh init_rag.py

# Run initialization
ENTRYPOINT ["/bin/bash", "-c", "\
    set -e; \
    echo '===================================='; \
    echo 'CVGen Initialization Container'; \
    echo '===================================='; \
    echo ''; \
    echo '[1/4] Waiting for Ollama to be healthy...'; \
    max_attempts=60; \
    attempt=0; \
    while [ $attempt -lt $max_attempts ]; do \
      if curl -f http://ollama:11434/api/tags > /dev/null 2>&1; then \
        echo '✓ Ollama is healthy'; \
        break; \
      fi; \
      attempt=$((attempt + 1)); \
      if [ $attempt -eq $max_attempts ]; then \
        echo '✗ Ollama failed to become healthy'; \
        exit 1; \
      fi; \
      echo \"  Attempt $attempt/$max_attempts...\"; \
      sleep 2; \
    done; \
    echo ''; \
    \
    echo '[2/4] Waiting for Qdrant to be healthy...'; \
    max_attempts=60; \
    attempt=0; \
    while [ $attempt -lt $max_attempts ]; do \
      if curl -f http://qdrant:6333/health > /dev/null 2>&1; then \
        echo '✓ Qdrant is healthy'; \
        break; \
      fi; \
      attempt=$((attempt + 1)); \
      if [ $attempt -eq $max_attempts ]; then \
        echo '✗ Qdrant failed to become healthy'; \
        exit 1; \
      fi; \
      echo \"  Attempt $attempt/$max_attempts...\"; \
      sleep 2; \
    done; \
    echo ''; \
    \
    echo '[3/4] Pulling Ollama model: \$OLLAMA_MODEL...'; \
    curl -X POST http://ollama:11434/api/pull -d '{\"name\":\"'\$OLLAMA_MODEL'\"}' || echo 'Note: Model may already exist'; \
    echo '✓ Model pull completed'; \
    echo ''; \
    \
    echo '[4/4] Initializing RAG knowledge base...'; \
    python init_rag.py || echo 'Warning: RAG initialization had issues, but service may still be functional'; \
    echo ''; \
    \
    echo '===================================='; \
    echo 'CVGen Initialization Complete!'; \
    echo '===================================='; \
    echo ''; \
    echo 'Services:'; \
    echo '  • CVGen API: http://localhost:8000'; \
    echo '  • Ollama:    http://localhost:11434'; \
    echo '  • Qdrant:    http://localhost:6333'; \
    echo ''; \
    echo 'Visit http://localhost:8000 to access CVGen'; \
    echo ''; \
"]
