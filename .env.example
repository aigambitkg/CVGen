# ================================================================
# CVGen - Quantum Computing for Every Device
# Docker Compose Configuration
# ================================================================
# Copy this file to .env and customize for your setup
# ================================================================

# ================================================================
# CVGen API Configuration
# ================================================================
CVGEN_PORT=8000
CVGEN_HOST=0.0.0.0
CVGEN_LOG_LEVEL=INFO

# Internal API URL for service-to-service communication
CVGEN_API_URL=http://cvgen:8000

# ================================================================
# Ollama LLM Backend Configuration
# ================================================================
# Ollama is a local LLM runtime that provides inference capabilities
# to CVGen for code generation, documentation, and AI agents

# Ollama service endpoint
OLLAMA_HOST=http://ollama:11434

# Model selection:
# - phi3:mini       (3.8B, <2GB RAM) - Fast, lightweight
# - qwen2.5:7b      (7B, 4-8GB RAM)  - Balanced, recommended
# - qwen2.5:14b     (14B, 10GB RAM)  - Better quality
# - qwen2.5:32b     (32B, 20GB RAM)  - Highest quality
# - mistral:latest  (7B, 4-8GB RAM)  - Fast, good coding
# - neural-chat     (7B, 4-8GB RAM)  - Optimized for chat
OLLAMA_MODEL=qwen2.5:7b

# ================================================================
# Qdrant Vector Database Configuration
# ================================================================
# Qdrant stores document embeddings for RAG (Retrieval Augmented Generation)
# enabling CVGen agents to reference QPanda3 documentation and code examples

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=cvgen_qpanda3

# ================================================================
# Origin Pilot - Quantum Backend Configuration
# ================================================================
# Origin Pilot provides local quantum circuit simulation and execution
# Falls back to pure quantum circuit simulation if unavailable

# Origin Pilot ZMQ connection (if running locally)
ORIGIN_PILOT_HOST=localhost
ORIGIN_PILOT_JOB_PORT=5555
ORIGIN_PILOT_TELEMETRY_PORT=5556

# ================================================================
# IBM Quantum Cloud Backend (Optional)
# ================================================================
# Requires IBM Quantum account at https://quantum.ibm.com
# Uncomment and set IBM_QUANTUM_TOKEN to enable

# IBM Quantum API Token (create at https://quantum.ibm.com/account)
# IBM_QUANTUM_TOKEN=your-ibm-quantum-token-here

# IBM Backend selection:
# - ibm_brisbane, ibm_kyoto, ibm_heron (latest small devices)
# - simulator_statevector (free cloud simulator)
IBM_QUANTUM_BACKEND=ibm_brisbane

# ================================================================
# AWS Braket Quantum Backend (Optional)
# ================================================================
# Requires AWS account with Braket service enabled
# Uncomment and configure to enable

# AWS region where Braket resources are available
# AWS_DEFAULT_REGION=us-east-1

# AWS credentials (use IAM roles in production for security)
# AWS_ACCESS_KEY_ID=your-aws-access-key-here
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here

# S3 bucket for Braket job results (must exist and be accessible)
# CVGEN_BRAKET_S3_BUCKET=your-braket-results-bucket

# ================================================================
# Azure Quantum Backend (Optional)
# ================================================================
# Requires Azure account with Quantum service
# Uncomment and set AZURE_QUANTUM_RESOURCE_ID to enable

# Azure Quantum resource identifier
# Format: /subscriptions/{subscription-id}/resourceGroups/{rg-name}/providers/Microsoft.Quantum/Workspaces/{workspace-name}
# AZURE_QUANTUM_RESOURCE_ID=/subscriptions/your-sub-id/resourceGroups/your-rg/providers/Microsoft.Quantum/Workspaces/your-workspace

# Azure region
AZURE_QUANTUM_LOCATION=eastus

# ================================================================
# Advanced Configuration (Usually not needed)
# ================================================================

# Docker resource limits (optional)
# COMPOSE_PROFILES=with-gpu  # Uncomment to enable GPU support

# Logging
# CVGen logs are written to /app/data/cvgen.log
# Ollama logs to stdout (visible with: docker logs cvgen-ollama)
# Qdrant logs to stdout (visible with: docker logs cvgen-qdrant)

# ================================================================
# Notes on Setup
# ================================================================
# 1. Start all services:
#    docker-compose -f docker-compose.full.yml up -d
#
# 2. Check service health:
#    bash scripts/health_check.sh
#
# 3. View logs:
#    docker logs cvgen-api
#    docker logs cvgen-ollama
#    docker logs cvgen-qdrant
#
# 4. Access CVGen Web UI:
#    http://localhost:8000
#
# 5. API Documentation (Swagger):
#    http://localhost:8000/docs
#
# 6. Ollama model management:
#    docker exec cvgen-ollama ollama ls
#    docker exec cvgen-ollama ollama pull mistral:latest
#
# 7. Qdrant Web UI (if needed):
#    http://localhost:6333/dashboard
